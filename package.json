{
	"name": "fogdex",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "node --env-file-if-exists=.env scripts/prepare-data.ts && astro build",
		"build:typecheck": "astro check",
		"data:pull": "node --env-file-if-exists=.env scripts/sync-data.ts pull",
		"data:push": "node --env-file-if-exists=.env scripts/sync-data.ts push",
		"dev": "astro dev",
		"fmt": "biome check --write",
		"lint": "biome check",
		"preview": "astro preview",
		"validate-data": "node --env-file-if-exists=.env scripts/validate-data.ts"
	},
	"dependencies": {
		"@astrojs/react": "^5.0.7",
		"@astrojs/sitemap": "^3.7.3",
		"astro": "^6.4.8",
		"nuqs": "^2.8.9",
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@aws-sdk/client-s3": "^3.1075.0",
		"@biomejs/biome": "^2.5.1",
		"@tailwindcss/vite": "^4.3.1",
		"@types/node": "^25.9.4",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"sharp": "^0.35.2",
		"tailwindcss": "^4.3.1",
		"typescript": "~6.0.3",
		"wrangler": "^4.105.0",
		"zod": "^4.4.3"
	},
	"packageManager": "pnpm@11.9.0"
}
