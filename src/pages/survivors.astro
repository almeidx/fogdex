---
import survivorsData from "../data/survivors.json";
import { SurvivorsIsland } from "../islands/SurvivorsIsland.tsx";
import BaseLayout from "../layouts/BaseLayout.astro";
import type { Survivor } from "../types/survivor.ts";

const survivors = survivorsData as Survivor[];

const title = "Survivors — Fogdex";
const description =
	"Filterable, sortable reference for every Dead by Daylight survivor — gender, origin, chapter, and licensed status.";

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "ItemList",
	itemListElement: survivors.map((s, i) => ({
		"@type": "ListItem",
		name: s.displayName,
		position: i + 1,
		url: `https://fogdex.almeidx.dev/survivors#${s.id}`,
	})),
	name: "Dead by Daylight Survivors",
	numberOfItems: survivors.length,
};
---

<BaseLayout title={title} description={description} h1="Dead by Daylight Survivors" jsonLd={jsonLd}>
	<SurvivorsIsland survivors={survivors} client:load />
</BaseLayout>
