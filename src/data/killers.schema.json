{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"items": {
		"additionalProperties": false,
		"properties": {
			"aliases": { "items": { "type": "string" }, "type": "array" },
			"attackCategory": { "enum": ["Melee", "Ranged", "Hybrid"], "type": "string" },
			"attackDetail": { "minLength": 1, "type": "string" },
			"chapter": { "minLength": 1, "type": "string" },
			"displayName": { "minLength": 1, "type": "string" },
			"gameTags": { "items": { "type": "string" }, "type": "array" },
			"gender": { "enum": ["Male", "Female", "Other"], "type": "string" },
			"height": { "enum": ["Short", "Average", "Tall"], "type": "string" },
			"id": { "pattern": "^K\\d{2}$", "type": "string" },
			"licensed": { "type": "boolean" },
			"lullabyNotes": { "type": ["string", "null"] },
			"lullabyRadius": { "minimum": 0, "type": ["number", "null"] },
			"origin": { "minLength": 1, "type": "string" },
			"portraitPath": { "type": "string" },
			"powerName": { "minLength": 1, "type": "string" },
			"realName": { "type": ["string", "null"] },
			"releaseDate": { "format": "date", "type": "string" },
			"slug": { "pattern": "^[a-z0-9-]+$", "type": "string" },
			"speed": { "minimum": 0, "type": "number" },
			"speedNotes": { "type": ["string", "null"] },
			"terrorRadius": { "minimum": 0, "type": "number" },
			"terrorRadiusNotes": { "type": ["string", "null"] },
			"weapon": { "minLength": 1, "type": "string" },
			"wikiUrl": { "format": "uri", "type": "string" }
		},
		"required": [
			"slug",
			"id",
			"displayName",
			"aliases",
			"gameTags",
			"gender",
			"origin",
			"speed",
			"terrorRadius",
			"attackCategory",
			"attackDetail",
			"height",
			"licensed",
			"lullabyRadius",
			"lullabyNotes",
			"releaseDate",
			"chapter",
			"powerName",
			"weapon",
			"portraitPath",
			"wikiUrl"
		],
		"type": "object"
	},
	"type": "array"
}
