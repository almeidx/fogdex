---
const path = Astro.url.pathname;

const links: { href: string; label: string }[] = [
	{ href: "/", label: "Killers" },
	{ href: "/survivors", label: "Survivors" },
	{ href: "/perks/killer", label: "Killer Perks" },
	{ href: "/perks/survivor", label: "Survivor Perks" },
];

function isActive(href: string): boolean {
	if (href === "/") return path === "/";
	return path === href;
}
---

<header class="border-b border-border bg-surface/95 backdrop-blur-sm">
	<div class="mx-auto max-w-350 flex flex-col gap-2 px-4 py-4 sm:flex-row sm:items-center sm:justify-between">
		<a class="text-2xl font-bold tracking-tight" href="/">
			Fog<span class="text-accent">dex</span>
		</a>
		<nav class="flex flex-wrap items-center gap-3 sm:gap-6">
			{
				links.map((link) => (
					<a
						class:list={[
							"text-sm py-1.5 transition-colors",
							isActive(link.href) ? "text-accent-text font-medium" : "text-text-muted hover:text-text",
						]}
						href={link.href}
					>
						{link.label}
					</a>
				))
			}
		</nav>
	</div>
</header>
